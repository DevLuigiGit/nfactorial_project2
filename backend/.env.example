# Local development (SQLite)
DATABASE_URL="file:./dev.db"

# Production (PostgreSQL on Railway)
# DATABASE_URL="postgresql://user:password@host:5432/jobboard"

PORT=3001

# Ollama Cloud (optional). If empty, AI assistant falls back to rule-based mode.
# Get a key at https://ollama.com/settings/keys
OLLAMA_API_KEY=
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=kimi-k2.6:cloud
